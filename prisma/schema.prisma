generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String    @unique
  password            String?
  image               String?
  role                String    @default("customer")
  phone               String?
  address             String?   // legacy single-address field (kept for compatibility)
  ntzsUserId          String?
  ntzsWalletAddress   String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  orders              Order[]
  reviews             Review[]
  cart                Cart?
  transactions        Transaction[]
  conversations       Conversation[]
  sentMessages        Message[]      @relation("MessageSender")
  addresses           Address[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String?  // "Home" | "Work" | "Other" | custom
  fullName  String
  phone     String?
  street    String
  city      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  description   String
  price         Float
  originalPrice Float?
  stock         Int         @default(0)
  images        String
  options       Json?
  featured      Boolean     @default(false)
  dealEndsAt    DateTime?
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  reviews       Review[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model Order {
  id              String           @id @default(cuid())
  userId          String
  status          String           @default("payment_confirmed")
  trackingId      String?          @unique
  total           Float
  address         String
  ntzsDepositId   String?
  user            User             @relation(fields: [userId], references: [id])
  items           OrderItem[]
  trackingEvents  TrackingEvent[]
  conversation    Conversation?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model TrackingEvent {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  message   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([orderId])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "deposit" | "withdrawal"
  amountTzs   Float
  status      String   // "pending" | "completed" | "failed" | "requested"
  phoneNumber String?
  ntzsId      String?
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // "new_order" | "new_user"
  title     String
  body      String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
}

model DiscountCode {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String
  percent   Int      @default(10)
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([code])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Conversation {
  id             String    @id @default(cuid())
  userId         String
  orderId        String?   @unique
  subject        String
  status         String    @default("open")
  customerUnread Int       @default(0)
  adminUnread    Int       @default(0)
  lastMessageAt  DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  order          Order?    @relation(fields: [orderId], references: [id])
  messages       Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String?
  senderRole     String
  body           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User?        @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)
}
