# PostgreSQL (Neon) — neon.tech dashboard → Connection Details
DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-domain.vercel.app"

# Vercel Blob — Vercel dashboard → Storage → Blob → .env.local tab
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxx"

# nTZS Payments — ntzs.co.tz dashboard → API Keys
NTZS_API_KEY="ntzs_live_xxxx"
# nTZS Webhooks — ntzs.co.tz dashboard → Webhooks → Secret
NTZS_WEBHOOK_SECRET="your-webhook-secret-here"
